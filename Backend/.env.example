# ===============================
# Core Django
# ===============================
SECRET_KEY=your-django-secret-key-here-min-50-chars
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.com
AUTH_USER_MODEL=account.User

# ===============================
# Database — PostgreSQL
# ===============================
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://edukai_user:strongpassword@postgres:5432/edukai_db

# ===============================
# Security (Set True in production)
# ===============================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# ===============================
# CORS & CSRF
# ===============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===============================
# Simple JWT
# ===============================
SIMPLE_JWT_ACCESS_TOKEN_HOURS=1
SIMPLE_JWT_REFRESH_TOKEN_DAYS=7
SIMPLE_JWT_ROTATE_REFRESH_TOKENS=True
SIMPLE_JWT_BLACKLIST_AFTER_ROTATION=True

# ===============================
# Redis & Celery
# ===============================
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===============================
# App
# ===============================
APP_NAME=EduKai

# ===============================
# Password Reset
# ===============================
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_TTL=600
PASSWORD_RESET_VERIFIED_TTL=600
PASSWORD_RESET_RESEND_COOLDOWN=60
PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=5
PASSWORD_RESET_MAX_VERIFY_ATTEMPTS=5
PASSWORD_RESET_OTP_PEPPER=replace-this-with-random-secret

# ===============================
# MinIO / S3 Storage
# ===============================
USE_S3=True
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=edukai
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_INTERNAL_URL=http://minio:9000
MINIO_REGION=us-east-1
PRESIGNED_URL_EXPIRE_SECONDS=86400

# ===============================
# AI Service
# ===============================
AI_BASE_URL=http://ai:8080
AI_POLL_INTERVAL_SECONDS=30
AI_POLL_MAX_RETRIES=60

# ===============================
# Email Service (SendGrid or others)
# ===============================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=example@yourdomain.com
SENDGRID_FROM_NAME=Your App Name
SENDGRID_REPLY_TO_EMAIL=reply@yourdomain.com
SENDGRID_REPLY_TO_NAME=Support Team

# ===============================
# CV Logo Path
# ===============================
CV_LOGO_PATH=/app/media/images/CV_logo.png